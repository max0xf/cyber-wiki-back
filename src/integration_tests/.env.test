# Integration Test Configuration
# This file mirrors the configuration used by run-local.sh
# Copy this file to .env.test and fill in your values

# API Server Configuration
API_URL=http://localhost:8000
API_TOKEN=your-api-token-here

# Django Settings (matches run-local.sh defaults)
DJANGO_SECRET_KEY=dev-local-secret-key-change-in-staging
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Encryption key for service tokens (matches .env.dev pattern)
ENCRYPTION_KEY=dev-encryption-key-change-in-production-must-be-32-bytes-base64==

# Git Provider Configuration (for git provider integration tests)
# These match the service token configuration in the app
TEST_GIT_PROVIDER=bitbucket_server
TEST_GIT_BASE_URL=https://bitbucket.example.com
TEST_GIT_USERNAME=your-username
TEST_GIT_TOKEN=your-git-token

# Database Configuration (optional, uses test database by default)
# TEST_DATABASE_NAME=test_db.sqlite3

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (optional, defaults to SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/cyberwiki

# Git Provider Settings (optional)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Git Edit Workflow Settings (for worktree-based editing)
# Path to SSH private key for git operations
# DOCLAB_GIT_SSH_KEY=/etc/doclab/git-ssh-key
# Directory for caching bare repositories
# DOCLAB_GIT_CACHE_DIR=/data/doclab/git-cache
# Directory for temporary worktrees
# DOCLAB_GIT_WORKTREE_DIR=/tmp/doclab-worktrees

# Service account for Bitbucket API operations (PR creation)
# DOCLAB_SERVICE_BITBUCKET_URL=https://git.example.com
# DOCLAB_SERVICE_BITBUCKET_USERNAME=doclab-service
# DOCLAB_SERVICE_BITBUCKET_TOKEN=your-http-access-token
